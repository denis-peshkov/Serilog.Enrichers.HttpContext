<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
	<metadata>
		<id>Serilog.Enrichers.HttpContext</id>
		<version>8.0.0</version>
		<title>Serilog.Enrichers.HttpContext</title>
		<authors>denis-peshkov</authors>
		<owners>denis-peshkov</owners>
		<license type="expression">MIT</license>
		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<projectUrl>https://github.com/denis-peshkov/Serilog.Enrichers.HttpContext</projectUrl>
		<repository type="git" url="https://github.com/denis-peshkov/Serilog.Enrichers.HttpContext" />
		<readme>docs\README.md</readme>
		<icon>icon.png</icon>
		<releaseNotes>
			Add MemoryUsage enricher.
		</releaseNotes>
		<description>Enriches Serilog events with client IP, RequestBody, RequestQuery, HTTP request headers and memory usage. Correlation Id can be added via WithRequestHeader.</description>
		<tags>serilog enrichers enricher ip correlationid request header body query memory memoryusage</tags>
		<copyright>Copyright 2026 Denis Peshkov</copyright>
		<dependencies>
			<group targetFramework="netstandard2.1">
				<dependency id="Microsoft.AspNetCore.Http" version="2.3.9" />
				<dependency id="Serilog" version="4.3.1" />
			</group>
			<group targetFramework="net6.0">
				<dependency id="Serilog" version="4.3.1" />
			</group>
			<group targetFramework="net7.0">
				<dependency id="Serilog" version="3.1.1" />
			</group>
			<group targetFramework="net8.0">
				<dependency id="Serilog" version="4.3.1" />
			</group>
			<group targetFramework="net9.0">
				<dependency id="Serilog" version="4.3.1" />
			</group>
			<group targetFramework="net10.0">
				<dependency id="Serilog" version="4.3.1" />
			</group>
		</dependencies>
		<frameworkReferences>
			<group targetFramework="net6.0">
				<frameworkReference name="Microsoft.AspNetCore.App" />
			</group>
			<group targetFramework="net7.0">
				<frameworkReference name="Microsoft.AspNetCore.App" />
			</group>
			<group targetFramework="net8.0">
				<frameworkReference name="Microsoft.AspNetCore.App" />
			</group>
			<group targetFramework="net9.0">
				<frameworkReference name="Microsoft.AspNetCore.App" />
			</group>
			<group targetFramework="net10.0">
				<frameworkReference name="Microsoft.AspNetCore.App" />
			</group>
		</frameworkReferences>
	</metadata>
	<files>
		<file src="src\Serilog.Enrichers.HttpContext\bin\Release\netstandard2.1\Serilog.Enrichers.HttpContext.*" target="lib/netstandard2.1" />
